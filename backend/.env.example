# Helios2 Environment Variables
# Copy this to .env and fill in your values

# OpenAI or compatible LLM API
OPENAI_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Or use MiniMax
# OPENAI_API_KEY=your_minimax_key
# LLM_BASE_URL=https://api.minimax.chat/v1
# LLM_MODEL=mini-max/MiniMax-M2.5

# Database
DATABASE_URL=sqlite:///./helios2.db

# Server
HOST=0.0.0.0
PORT=8001
