# Helios2 Environment Configuration
# Copy this file to .env and fill in your values

# MiniMax API Key (get from https://platform.minimax.io)
MINIMAX_API_KEY=your_api_key_here

# Database (optional - defaults to helios2.db in backend folder)
# DATABASE_URL=sqlite:///./helios2.db

# Server (optional)
# HOST=0.0.0.0
# PORT=8001
